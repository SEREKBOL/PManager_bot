async def set_bot_commands(app):
    # Энгийн хэрэглэгчдэд харагдах команд
    user_commands = [
        BotCommand("start", "🤖 Start bot 💪"),
    ]

    # Admin-д харагдах команд
    admin_commands = [
        BotCommand("start", "🤖 Start bot 💪"),
        BotCommand("list", "📋 List members ✨"),
        BotCommand("add", "➕ Add member 👑"),
        BotCommand("remove", "🚫 Delete member"),
    ]

    # Бүх хэрэглэгчдэд start команд харуулна
    await app.bot.set_my_commands(user_commands)

    # Admin-д тусгай команд харуулах
    try:
        await app.bot.set_my_commands(
            admin_commands,
            scope=BotCommandScopeChat(chat_id=MASTER_ADMIN_ID)
        )
    except Exception as e:
        logger.error(f"Error setting admin commands: {e}")


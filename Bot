def is_master_admin(user_id):
    return str(user_id) == MASTER_ADMIN_ID

def is_allowed(user_id):
    return is_master_admin(user_id) or str(user_id) in allowed_users

async def send_access_denied(update: Update):
    try:
        await update.message.reply_text(
            ACCESS_DENIED_MESSAGE,
            parse_mode='Markdown'
        )
    except:
        pass

class CPMApiClient:
    def __init__(self):
        self.base_url = API_BASE_URL
        self.api_key = API_KEY

    async def make_request(self, endpoint: str, data: dict) -> Dict:
        url = f"{self.base_url}/{endpoint}"
        params = {"api_key": self.api_key}

        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(url, params=params, json=data, timeout=30) as response:
                    if response.status == 200:
                        response_data = await response.json()
                        if response_data.get("error") == 0 and response_data.get("ok"):
                            return {"ok": True, "data": response_data}
                        else:
                            return {"ok": False, "error": response_data.get("message", "An error occurred")}
                    else:
                        return {"ok": False, "error": f"HTTP error {response.status}"}
        except Exception as e:
            return {"ok": False, "error": str(e)}

    async def register(self, email: str, password: str) -> Dict:
        return await self.make_request("account_register", {
            "account_email": email,
            "account_password": password
        })

    async def login(self, email: str, password: str) -> Dict:
        return await self.make_request("account_login", {
            "account_email": email,
            "account_password": password
        })

    async def set_rank(self, auth_token: str) -> Dict:
        return await self.make_request("set_rank", {
            "account_auth": auth_token
        })

    async def change_password(self, auth_token: str, new_password: str) -> Dict:
        return await self.make_request("change_password", {
            "account_auth": auth_token,
            "new_password": new_password
        })

    async def change_email(self, auth_token: str, new_email: str) -> Dict:
        return await self.make_request("change_email", {
            "account_auth": auth_token,
            "new_email": new_email
        })

    async def delete_account(self, auth_token: str) -> Dict:
        return await self.make_request("delete_account", {
            "account_auth": auth_token
        })

# ========== ACCESS CONTROL - ЮУ Ч ИЛГЭЭХГҮЙ ==========
async def access_control(update: Update, context: ContextTypes.DEFAULT_TYPE):
    try:
        user_id = str(update.effective_user.id)

        if user_id in user_sessions:
            user_sessions[user_id]['last_activity'] = time.time()

        if not is_allowed(user_id):
            await send_access_denied(update)
            return False

        return True

    except Exception as e:
        logger.error(f"Error in access_control: {e}")
        return False

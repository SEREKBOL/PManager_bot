# Main message handler
async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await access_control(update, context):
        return

    if not update.message or not update.message.text:
        return

    text = update.message.text
    user_id = str(update.effective_user.id)
    user = update.effective_user

    if user_id not in user_sessions:
        user_sessions[user_id] = {
            'auth_token': None,
            'email': None,
            'last_activity': time.time()
        }

    user_sessions[user_id]['last_activity'] = time.time()

    # ===== ADMIN COMMANDS STATE - ID АСУУХ ХЭСЭГ =====
    if user_id in user_states:
        state = user_states[user_id]

        # Add command state - ID хүлээж авах
        if state == 'awaiting_add_id':
            new_user_id = text.strip()

            if not new_user_id.isdigit():
                await update.message.reply_text(
                    "❌ ID must contain only numbers! Try again or use /add to restart.",
                    parse_mode='Markdown'
                )
                return

            if new_user_id in allowed_users:
                await update.message.reply_text(
                    f"❌ `{new_user_id}` is already a member!",
                    parse_mode='Markdown'
                )
            elif new_user_id == MASTER_ADMIN_ID:
                await update.message.reply_text(
                    "❌ Master admin is always a member!",
                    parse_mode='Markdown'
                )
            else:
                allowed_users.append(new_user_id)
                save_allowed_users(allowed_users)

                await update.message.reply_text(
                    f"✅ Member `{new_user_id}` successfully added! 😉",
                    parse_mode='Markdown'
                )

                # Шинэ хэрэглэгчдэд мэдэгдэх
                try:
                    await context.bot.send_message(
                        chat_id=new_user_id,
                        text="✅ **WELCOME!**\n\nYou now have access to use this bot!\nPress /start to begin.",
                        parse_mode='Markdown'
                    )
                except:
                    pass

            # Төлөвийг арилгах
            del user_states[user_id]
            return

        # Remove command state - ID хүлээж авах
        elif state == 'awaiting_remove_id':
            remove_user_id = text.strip()

            if not remove_user_id.isdigit():
                await update.message.reply_text(
                    "❌ ID must contain only numbers! Try again or use /remove to restart.",
                    parse_mode='Markdown'
                )
                return

            if remove_user_id not in allowed_users:
                await update.message.reply_text(
                    f"❌ `{remove_user_id}` is not a member!",
                    parse_mode='Markdown'
                )
            else:
                allowed_users.remove(remove_user_id)
                save_allowed_users(allowed_users)

                await update.message.reply_text(
                    f"✅ Member `{remove_user_id}` successfully deleted! 🚫",
                    parse_mode='Markdown'
                )

                # Устгагдсан хэрэглэгчдэд мэдэгдэх
                try:
                    await context.bot.send_message(
                        chat_id=remove_user_id,
                        text="⛔ **ACCESS REVOKED** ⛔\n\nYour access has been removed.",
                        parse_mode='Markdown'
                    )
                except:
                    pass

            # Төлөвийг арилгах
            del user_states[user_id]
            return

    # ===== BUTTON HANDLERS =====
    if text == "📝 Register":
        await handle_register(update, context)
    elif text == "🔑 Login":
        await handle_login(update, context)
    elif text == "⭐ Set Rank":
        await handle_set_rank(update, context)
    elif text == "🔒 Change Password":
        await handle_change_password(update, context)
    elif text == "📧 Change Email":
        await handle_change_email(update, context)
    elif text == "📊 My Info":
        await handle_my_info(update, context)
    elif text == "🗑️ Delete Account":
        await handle_delete_account(update, context)
    elif text == "❌ Logout":
        await handle_logout(update, context)
    else:
        # State handlers
        state = context.user_data.get('state')

        if state == 'register_email':
            context.user_data['reg_email'] = text
            context.user_data['state'] = 'register_password'
            await update.message.reply_text("🔑 Please enter your password:")

        elif state == 'register_password':
            email = context.user_data.get('reg_email')
            password = text

            if len(password) < 6:
                await update.message.reply_text("❌ Password must be at least 6 characters! Please enter again:")
                return

            await update.message.reply_text("⏳ Registering...")

            client = CPMApiClient()
            response = await client.register(email, password)

            if response["ok"]:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text("✅ Registration successful! You can now login.", reply_markup=keyboard)
            else:
                error_msg = response.get('error', 'Registration failed')
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                if "already exists" in error_msg.lower():
                    await update.message.reply_text("❌ This email is already registered!", reply_markup=keyboard)
                else:
                    await update.message.reply_text(f"❌ Error: {error_msg}", reply_markup=keyboard)

            context.user_data.clear()

        elif state == 'login_email':
            context.user_data['login_email'] = text
            context.user_data['state'] = 'login_password'
            await update.message.reply_text("🔑 Please enter your password:")

        elif state == 'login_password':
            email = context.user_data.get('login_email')
            password = text

            await update.message.reply_text("⏳ Logging in...")

            client = CPMApiClient()
            response = await client.login(email, password)

            if response["ok"]:
                auth_token = response["data"].get("auth")
                user_sessions[user_id]['auth_token'] = auth_token
                user_sessions[user_id]['email'] = email
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text(f" ✅ Welcome {email}!\nYou have successfully logged in!", reply_markup=keyboard)
            else:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text(f" ❌ Error: {response.get('error', 'Login failed')}", reply_markup=keyboard)

            context.user_data.clear()

        elif state == 'change_password':
            new_password = text

            if len(new_password) < 6:
                await update.message.reply_text("❌ Password must be at least 6 characters! Please enter again:")
                return

            await update.message.reply_text("⏳ Changing password...")

            client = CPMApiClient()
            response = await client.change_password(user_sessions[user_id]['auth_token'], new_password)

            if response["ok"]:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text("✅ Password changed successfully!", reply_markup=keyboard)
            else:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text(f" ❌ Error: {response.get('error', 'Failed to change password')}", reply_markup=keyboard)

            context.user_data.clear()

        elif state == 'change_email':
            new_email = text

            if '@' not in new_email or '.' not in new_email:
                await update.message.reply_text("❌ Please enter a valid email address!")
                return

            await update.message.reply_text("⏳ Changing email...")

            client = CPMApiClient()
            response = await client.change_email(user_sessions[user_id]['auth_token'], new_email)

            if response["ok"]:
                user_sessions[user_id]['email'] = new_email
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text("✅ Email changed successfully!", reply_markup=keyboard)
            else:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text(f" ❌ Error: {response.get('error', 'Failed to change email')}", reply_markup=keyboard)

            context.user_data.clear()

        elif state == 'confirm_delete':
            if text.upper() == "YES":
                await update.message.reply_text("⏳ Deleting account...")

                client = CPMApiClient()
                response = await client.delete_account(user_sessions[user_id]['auth_token'])

                if response["ok"]:
                    user_sessions[user_id] = {
                        'auth_token': None,
                        'email': None,
                        'last_activity': time.time()
                    }
                    keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                    await update.message.reply_text("✅ Account deleted successfully!", reply_markup=keyboard)
                else:
                    keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                    await update.message.reply_text(f"❌ Error: {response.get('error', 'Failed to delete account')}", reply_markup=keyboard)
            else:
                keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
                await update.message.reply_text("❌ Account deletion cancelled.", reply_markup=keyboard)

            context.user_data.clear()

        else:
            keyboard = get_admin_keyboard() if is_master_admin(user_id) else get_user_keyboard()
            await update.message.reply_text("❌ Invalid command! Please use the buttons below 👇", reply_markup=keyboard)

# New chat members handler
async def handle_new_chat_members(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not update.message or not update.message.new_chat_members:
        return

    for member in update.message.new_chat_members:
        if member.id == context.bot.id:
            return

    user_id = str(update.effective_user.id)
    if not is_allowed(user_id):
        await send_access_denied(update)

